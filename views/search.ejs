<%- include('./includes/header.ejs') %>
<title>Search</title>
</head>
<body>
    <div class="row m-0 p-0 justify-content-center mt-5">
        <img src="/img/clapperboard.svg" alt="" class="col-4 col-md-2 col-lg-2" />
    </div>
    <form action="/" method="POST">
        <div class="row m-0 p-0 justify-content-center mt-3">
            <input type="text" id="title" name="title" class="col-6 form-control" style="width: 50%;">
        </div>
        <div class="row m-0 p-0 justify-content-center mt-2">
            <select name="types" id="type" class="form-control" style="width: 30%;">
                <option value="movie">Movie</option>
                <option value="tv show">TV Show</option>
              </select>
        </div>
        <div class="row m-0 p-0 justify-content-center mt-2">
            <button type="submit" class="btn btn-dark col-3">Search</button>
        </div>
    </form>
</body>
</html>